<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Social Studies GradeMonitor Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        [v-cloak] { display: none; }
        .grade-input { width: 50px; text-align: center; border-bottom: 1px solid #e2e8f0; outline: none; }
        .grade-input:focus { border-bottom-color: #2563eb; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">
    <div id="app" v-cloak class="flex h-screen overflow-hidden">
        
        <aside class="w-64 bg-slate-900 text-white flex flex-col p-4 shrink-0">
            <div class="flex items-center gap-3 mb-8 px-2">
                <div class="p-2 bg-blue-600 rounded-lg">
                    <i data-lucide="graduation-cap"></i>
                </div>
                <h1 class="font-bold text-sm leading-tight">SOCIAL STUDIES<br>MONITOR</h1>
            </div>

            <div class="mb-6 px-2">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 block">Academic Cycle</label>
                <select v-model="selectedAcademicYear" class="w-full bg-slate-800 border-none rounded px-3 py-2 text-sm font-bold text-blue-400">
                    <option value="25-26">2025/26</option>
                    <option value="26-27">2026/27</option>
                </select>
            </div>

            <nav class="space-y-1">
                <button @click="view = 'home'" :class="view === 'home' ? 'bg-blue-600 text-white' : 'text-slate-400 hover:bg-slate-800'" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                    <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Homepage
                </button>
                <hr class="border-slate-800 my-4">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-3 mb-2 block">Subject Domains</label>
                <button v-for="sub in subjects" :key="sub" @click="selectSubject(sub)" :class="selectedSubject === sub && view === 'subject' ? 'bg-slate-800 text-blue-400 border-l-4 border-blue-400' : 'text-slate-400 hover:bg-slate-800'" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                    <i data-lucide="book-open" class="w-4 h-4"></i> {{ sub }}
                </button>
            </nav>
        </aside>

        <main class="flex-1 overflow-y-auto flex flex-col">
            
            <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0">
                <h2 class="font-bold text-slate-500 uppercase tracking-tighter text-xs">
                    {{ view === 'home' ? 'Departmental Overview' : selectedSubject }}
                </h2>
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center overflow-hidden border border-slate-300">
                        <img v-if="schoolLogo" :src="schoolLogo" class="object-contain">
                        <i v-else data-lucide="user" class="w-4 h-4 text-slate-400"></i>
                    </div>
                </div>
            </header>

            <section v-if="view === 'home'" class="p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="font-black text-red-600 text-xs uppercase tracking-widest flex items-center gap-2">
                                <i data-lucide="alert-circle" class="w-4 h-4"></i> Priority Interventions
                            </h3>
                            <span class="text-[10px] bg-red-50 text-red-600 px-2 py-1 rounded-full font-bold">{{ concerns.length }} Declining</span>
                        </div>
                        <div class="space-y-3">
                            <div v-for="c in concerns" :key="c.id" @click="openDirectory(c.studentId)" class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-red-200 cursor-pointer transition-all">
                                <div>
                                    <p class="text-xs font-bold">{{ getStudentName(c.studentId) }}</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase">{{ c.subject }} • Year {{ getStudentYear(c.studentId) }}</p>
                                </div>
                                <span class="text-xs font-black text-red-600">▼ {{ c.evaluation }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                        <h3 class="font-black text-blue-600 text-xs uppercase tracking-widest flex items-center gap-2 mb-6">
                            <i data-lucide="calendar" class="w-4 h-4"></i> Cycle Deadlines
                        </h3>
                        <div class="space-y-4">
                            <div class="flex justify-between items-center text-sm">
                                <span class="font-medium">P3 Data Entry (All Subjects)</span>
                                <span class="text-red-500 font-black">24 Apr 2026</span>
                            </div>
                            <div class="flex justify-between items-center text-sm opacity-40">
                                <span class="font-medium">Year 13 Final Comments</span>
                                <span class="font-bold">Completed</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section v-if="view === 'subject'" class="p-8 space-y-6">
                <div class="flex flex-wrap gap-4 items-end bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase mb-1 block">Year Group</label>
                        <select v-model="filters.year" class="text-xs font-bold border rounded p-2 outline-none">
                            <option value="All">All Year Groups</option>
                            <option v-for="y in [7,8,9,10,11,12,13]" :value="y">Year {{ y }}</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase mb-1 block">Class</label>
                        <select v-model="filters.class" class="text-xs font-bold border rounded p-2 outline-none">
                            <option value="All">All Classes</option>
                            <option v-for="c in availableClasses" :value="c">{{ c }}</option>
                        </select>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b">
                                <th class="p-4">Student Profile</th>
                                <th class="p-4">Teacher/Class</th>
                                <th class="p-4 text-center">{{ isSeniorCycle ? 'End of Prev. Year' : 'Aspirational' }}</th>
                                <th v-if="isSeniorCycle" class="p-4 text-center">P1</th>
                                <th class="p-4 text-center">P2</th>
                                <th class="p-4 text-center">P3</th>
                                <th class="p-4 text-center">P4</th>
                                <th v-if="isIBLevel" class="p-4 text-center">Level</th>
                                <th class="p-4 text-center">Evaluation</th>
                                <th class="p-4">Intervention Notes</th>
                                <th class="p-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-xs">
                            <tr v-for="row in filteredGrades" :key="row.id" class="hover:bg-slate-50 group">
                                <td class="p-4">
                                    <button @click="openDirectory(row.studentId)" class="font-black text-blue-600 hover:underline text-left block">{{ getStudentName(row.studentId) }}</button>
                                    <span class="text-[9px] font-bold text-slate-400 uppercase">SEN: {{ getStudentSEN(row.studentId) }} | CEFR: {{ getStudentCEFR(row.studentId) }}</span>
                                </td>
                                <td class="p-4">
                                    <p class="font-medium">{{ row.teacher }}</p>
                                    <p class="text-[10px] text-slate-400">{{ getStudentClass(row.studentId) }}</p>
                                </td>
                                <td class="p-4 text-center"><input v-model="row.aspirational" class="grade-input"></td>
                                <td v-if="isSeniorCycle" class="p-4 text-center"><input v-model="row.p1" class="grade-input"></td>
                                <td class="p-4 text-center"><input v-model="row.p2" class="grade-input"></td>
                                <td class="p-4 text-center"><input v-model="row.p3" class="grade-input"></td>
                                <td class="p-4 text-center"><input v-model="row.p4" class="grade-input"></td>
                                
                                <td v-if="isIBLevel" class="p-4 text-center">
                                    <select v-model="row.level" class="font-bold border rounded px-1 text-[10px]">
                                        <option value="SL">SL</option>
                                        <option value="HL">HL</option>
                                    </select>
                                </td>

                                <td class="p-4 text-center">
                                    <button @click="toggleEval(row)" :class="getEvalClass(row.evaluation)" class="px-2 py-1 rounded-full font-black text-[9px] uppercase transition-all">
                                        {{ row.evaluation }}
                                    </button>
                                </td>

                                <td class="p-4">
                                    <textarea v-model="row.comment" class="w-full bg-slate-50 border rounded p-1 text-[10px]" rows="1" placeholder="Add support..."></textarea>
                                </td>

                                <td class="p-4 text-right space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @click="moveStudent(row.studentId)" class="text-slate-400 hover:text-blue-600"><i data-lucide="shuffle" class="w-4 h-4"></i></button>
                                    <button @click="purgeStudent(row.studentId)" class="text-slate-400 hover:text-red-600"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <div v-if="directoryStudent" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
                <div class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden">
                    <div class="p-6 border-b flex justify-between items-center bg-slate-50">
                        <div>
                            <h3 class="text-xl font-black">{{ directoryStudent.name }}</h3>
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Year {{ directoryStudent.yearGroup }} • {{ directoryStudent.classGroup }}</p>
                        </div>
                        <button @click="directoryStudent = null" class="text-slate-400 hover:text-slate-600">✕</button>
                    </div>
                    <div class="p-6">
                        <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Holistic Achievement ({{ selectedAcademicYear }})</h4>
                        <div class="grid grid-cols-1 gap-3">
                            <div v-for="g in getStudentCrossGrades(directoryStudent.id)" class="flex items-center justify-between p-4 bg-slate-50 rounded-xl border">
                                <span class="font-black text-sm">{{ g.subject }}</span>
                                <div class="flex gap-4 items-center">
                                    <span class="text-xs font-bold text-slate-500">Latest Cycle: {{ g.p3 || g.p2 || '—' }}</span>
                                    <span :class="getEvalClass(g.evaluation)" class="px-2 py-1 rounded-full font-black text-[9px] uppercase">{{ g.evaluation }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script>
        const { createApp, ref, computed, onMounted, watch } = Vue;

        createApp({
            setup() {
                // --- STATE ---
                const view = ref('home');
                const selectedAcademicYear = ref('25-26');
                const selectedSubject = ref('History');
                const directoryStudent = ref(null);
                const schoolLogo = ref(null);

                const subjects = ["History", "Geography", "Psychology", "Sociology", "Philosophy", "Social Studies"];
                const filters = ref({ year: 'All', class: 'All' });

                // Mock Database
                const students = ref([
                    { id: '1', name: 'John Smith', yearGroup: '11', classGroup: '11A', sen: 'K', cefr: 'B2' },
                    { id: '2', name: 'Elena Rodriguez', yearGroup: '13', classGroup: '13B', sen: '—', cefr: 'C1' },
                    { id: '3', name: 'Mark Wu', yearGroup: '8', classGroup: '8C', sen: 'P', cefr: 'A2' }
                ]);

                const grades = ref([
                    { id: 'g1', studentId: '1', academicYear: '25-26', subject: 'History', aspirational: '7', p1: '6', p2: '6', p3: '5', evaluation: 'Declining', teacher: 'Mr. Jones', comment: 'Lacking focus in Paper 2' },
                    { id: 'g2', studentId: '1', academicYear: '25-26', subject: 'Psychology', aspirational: '6', p1: '6', p2: '7', p3: '7', evaluation: 'Improving', teacher: 'Ms. Lee', comment: '' },
                    { id: 'g3', studentId: '2', academicYear: '25-26', subject: 'Sociology', aspirational: '6', p1: '5', p2: '5', p3: '5', level: 'HL', evaluation: 'Stable', teacher: 'Mr. White', comment: '' }
                ]);

                // --- COMPUTED ---
                const filteredGrades = computed(() => {
                    return grades.value.filter(g => {
                        const s = students.value.find(st => st.id === g.studentId);
                        const matchSubject = g.subject === selectedSubject.value;
                        const matchYear = filters.value.year === 'All' || s.yearGroup == filters.value.year;
                        const matchClass = filters.value.class === 'All' || s.classGroup == filters.value.class;
                        const matchCycle = g.academicYear === selectedAcademicYear.value;
                        return matchSubject && matchYear && matchClass && matchCycle;
                    });
                });

                const concerns = computed(() => {
                    return grades.value.filter(g => g.evaluation === 'Declining' && g.academicYear === selectedAcademicYear.value);
                });

                const isSeniorCycle = computed(() => ['11', '13'].includes(filters.value.year.toString()));
                const isIBLevel = computed(() => ['12', '13'].includes(filters.value.year.toString()));

                const availableClasses = computed(() => {
                    const set = new Set();
                    students.value.forEach(s => set.add(s.classGroup));
                    return Array.from(set).sort();
                });

                // --- METHODS ---
                const selectSubject = (sub) => {
                    selectedSubject.value = sub;
                    view.value = 'subject';
                };

                const toggleEval = (row) => {
                    const cycles = ['Stable', 'Improving', 'Declining'];
                    const next = cycles[(cycles.indexOf(row.evaluation) + 1) % cycles.length];
                    row.evaluation = next;
                };

                const getEvalClass = (status) => {
                    if (status === 'Improving') return 'bg-emerald-100 text-emerald-700';
                    if (status === 'Declining') return 'bg-red-100 text-red-700';
                    return 'bg-amber-100 text-amber-700';
                };

                const openDirectory = (sid) => {
                    directoryStudent.value = students.value.find(s => s.id === sid);
                };

                const getStudentCrossGrades = (sid) => {
                    return grades.value.filter(g => g.studentId === sid && g.academicYear === selectedAcademicYear.value);
                };

                const moveStudent = (sid) => {
                    const newClass = prompt("Move to which class? (e.g., 11B)");
                    if (newClass) {
                        const s = students.value.find(st => st.id === sid);
                        s.classGroup = newClass;
                        alert(`${s.name} moved to ${newClass}. Data records linked by ID remain intact.`);
                    }
                };

                const purgeStudent = (sid) => {
                    if (confirm("PERMANENT PURGE: Delete this student from the school registry? This wipes all History, Geography, and other grade records for all years.")) {
                        students.value = students.value.filter(s => s.id !== sid);
                        grades.value = grades.value.filter(g => g.studentId !== sid);
                    }
                };

                // Helpers
                const getStudentName = (id) => students.value.find(s => s.id === id)?.name;
                const getStudentClass = (id) => students.value.find(s => s.id === id)?.classGroup;
                const getStudentYear = (id) => students.value.find(s => s.id === id)?.yearGroup;
                const getStudentSEN = (id) => students.value.find(s => s.id === id)?.sen;
                const getStudentCEFR = (id) => students.value.find(s => s.id === id)?.cefr;

                onMounted(() => {
                    lucide.createIcons();
                });

                watch([view, selectedSubject, directoryStudent], () => {
                    setTimeout(() => lucide.createIcons(), 10);
                });

                return {
                    view, selectedAcademicYear, selectedSubject, subjects, students, grades, filters,
                    filteredGrades, concerns, isSeniorCycle, isIBLevel, availableClasses,
                    selectSubject, toggleEval, getEvalClass, openDirectory, directoryStudent,
                    getStudentCrossGrades, moveStudent, purgeStudent,
                    getStudentName, getStudentClass, getStudentYear, getStudentSEN, getStudentCEFR, schoolLogo
                }
            }
        }).mount('#app');
    </script>
</body>
</html>
