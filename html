<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SS Grade Tracker | Global Citizens</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>

    <style>
        body { font-family: 'Inter', sans-serif; }
        .active-tab { border-bottom: 4px solid #3b82f6; color: #3b82f6; }
    </style>
</head>
<body class="bg-slate-50">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // 1. YOUR FIREBASE CONFIG
        const firebaseConfig = {
            apiKey: "AIzaSyA1fpS3ftTOuiiKCzB1RO_PB00IpDdcaHE",
            authDomain: "ssgradetracker.firebaseapp.com",
            projectId: "ssgradetracker",
            storageBucket: "ssgradetracker.firebasestorage.app",
            messagingSenderId: "271487711446",
            appId: "1:271487711446:web:6b4c2bad5f7ca693b17177"
        };

        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }
        const db = firebase.firestore();
        const STUDENTS_REF = db.collection('students');

        const App = () => {
            const [view, setView] = useState('dashboard'); // 'dashboard' or 'add'
            const [students, setStudents] = useState([]);
            const [formData, setFormData] = useState({ name: '', grade: '', target: '' });
            const [loading, setLoading] = useState(true);

            // 2. LIVE DATA SYNC (The "Success" Engine)
            useEffect(() => {
                const unsubscribe = STUDENTS_REF.orderBy('name').onSnapshot((snapshot) => {
                    const list = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                    setStudents(list);
                    setLoading(false);
                });
                return () => unsubscribe();
            }, []);

            // 3. SAVE FUNCTION (The "Explicit" Math Fix)
            const handleSave = (e) => {
                e.preventDefault();
                if (!formData.name) return alert("Enter a name");

                STUDENTS_REF.doc(formData.name).set({
                    name: formData.name,
                    grade: Number(formData.grade), // Force Number
                    target: Number(formData.target), // Force Number
                    lastUpdated: firebase.firestore.FieldValue.serverTimestamp()
                }, { merge: true });

                setFormData({ name: '', grade: '', target: '' });
                setView('dashboard'); // Auto-return to list
            };

            return (
                <div className="min-h-screen flex flex-col">
                    {/* Header: Mimicking your professional style */}
                    <header className="bg-slate-900 text-white p-6 shadow-xl">
                        <div className="max-w-4xl mx-auto flex justify-between items-center">
                            <div>
                                <h1 className="text-2xl font-bold tracking-tight">SS GRADE TRACKER</h1>
                                <p className="text-slate-400 text-xs">Curriculum & Progress Management</p>
                            </div>
                            <div className="flex gap-6">
                                <button 
                                    onClick={() => setView('dashboard')}
                                    className={`pb-1 font-medium transition ${view === 'dashboard' ? 'active-tab' : 'text-slate-400'}`}
                                >
                                    Dashboard
                                </button>
                                <button 
                                    onClick={() => setView('add')}
                                    className={`pb-1 font-medium transition ${view === 'add' ? 'active-tab' : 'text-slate-400'}`}
                                >
                                    Add Student
                                </button>
                            </div>
                        </div>
                    </header>

                    <main className="max-w-4xl mx-auto w-full p-6">
                        {/* VIEW: DASHBOARD */}
                        {view === 'dashboard' && (
                            <div className="space-y-4">
                                <div className="flex justify-between items-end mb-4">
                                    <h2 className="text-xl font-bold text-slate-800">Student Progress</h2>
                                    <span className="text-sm text-slate-500">{students.length} Students Tracked</span>
                                </div>
                                
                                {loading ? (
                                    <div className="p-10 text-center text-slate-400">Loading live data...</div>
                                ) : (
                                    <div className="grid gap-3">
                                        {students.map(s => (
                                            <div key={s.id} className="bg-white p-4 rounded-lg border border-slate-200 shadow-sm flex justify-between items-center hover:border-blue-300 transition">
                                                <div>
                                                    <h3 className="font-bold text-slate-700">{s.name}</h3>
                                                    <p className="text-xs text-slate-400">Target: {s.target}%</p>
                                                </div>
                                                <div className="flex items-center gap-4">
                                                    <div className="text-right">
                                                        <span className={`text-lg font-black ${s.grade >= s.target ? 'text-green-600' : 'text-amber-500'}`}>
                                                            {s.grade}%
                                                        </span>
                                                        <p className="text-[10px] uppercase font-bold text-slate-400">Current</p>
                                                    </div>
                                                    <button 
                                                        onClick={() => STUDENTS_REF.doc(s.id).delete()}
                                                        className="text-slate-300 hover:text-red-500 px-2"
                                                    >
                                                        ✕
                                                    </button>
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                )}
                            </div>
                        )}

                        {/* VIEW: ADD/EDIT */}
                        {view === 'add' && (
                            <div className="bg-white p-8 rounded-xl border border-slate-200 shadow-lg max-w-md mx-auto">
                                <h2 className="text-xl font-bold mb-6 text-slate-800 border-b pb-2">New Entry</h2>
                                <form onSubmit={handleSave} className="space-y-4">
                                    <div>
                                        <label className="block text-xs font-bold uppercase text-slate-500 mb-1">Student Name</label>
                                        <input 
                                            type="text" required
                                            value={formData.name}
                                            onChange={e => setFormData({...formData, name: e.target.value})}
                                            className="w-full p-3 bg-slate-50 border rounded-md outline-none focus:ring-2 ring-blue-500"
                                            placeholder="e.g. John Smith"
                                        />
                                    </div>
                                    <div className="grid grid-cols-2 gap-4">
                                        <div>
                                            <label className="block text-xs font-bold uppercase text-slate-500 mb-1">Current Grade (%)</label>
                                            <input 
                                                type="number" 
                                                value={formData.grade}
                                                onChange={e => setFormData({...formData, grade: e.target.value})}
                                                className="w-full p-3 bg-slate-50 border rounded-md outline-none focus:ring-2 ring-blue-500"
                                            />
                                        </div>
                                        <div>
                                            <label className="block text-xs font-bold uppercase text-slate-500 mb-1">Target (%)</label>
                                            <input 
                                                type="number" 
                                                value={formData.target}
                                                onChange={e => setFormData({...formData, target: e.target.value})}
                                                className="w-full p-3 bg-slate-50 border rounded-md outline-none focus:ring-2 ring-blue-500"
                                            />
                                        </div>
                                    </div>
                                    <button className="w-full bg-blue-600 text-white font-bold py-4 rounded-md hover:bg-blue-700 shadow-md transition-all active:scale-95">
                                        UPDATE TRACKER
                                    </button>
                                </form>
                            </div>
                        )}
                    </main>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
