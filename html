<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Social Studies Data Tracker</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Inter', 'sans-serif'] },
            colors: { school: { blue: '#0f172a', lightBlue: '#1e3a8a' } }
          }
        }
      }
    </script>
</head>
<body class="bg-gray-50 text-slate-800 antialiased">
    
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // --- 1. FIREBASE CONFIGURATION (Using your new ssgradetracker project) ---
        const firebaseConfig = {
            apiKey: "AIzaSyA1fpS3ftTOuiiKCzB1RO_PB00IpDdcaHE",
            authDomain: "ssgradetracker.firebaseapp.com",
            projectId: "ssgradetracker",
            storageBucket: "ssgradetracker.firebasestorage.app",
            messagingSenderId: "271487711446",
            appId: "1:271487711446:web:6b4c2bad5f7ca693b17177",
            measurementId: "G-6QC4NML8L7"
        };

        // Initialize Firebase
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }
        const db = firebase.firestore();
        
        // POINTING TO A COLLECTION (Better for data tracking than a single doc)
        const STUDENTS_REF = db.collection('students');

        // --- MAIN APP COMPONENT ---
        const DataTracker = () => {
            const [students, setStudents] = useState([]);
            const [newName, setNewName] = useState("");
            const [newGrade, setNewGrade] = useState("");
            const [loading, setLoading] = useState(true);

            // 2. LOAD DATA (Live Listener)
            useEffect(() => {
                const unsubscribe = STUDENTS_REF.onSnapshot((snapshot) => {
                    const data = snapshot.docs.map(doc => ({
                        id: doc.id,
                        ...doc.data()
                    }));
                    setStudents(data);
                    setLoading(false);
                }, (error) => {
                    console.error("Firebase Rule Error:", error);
                    setLoading(false);
                });
                return () => unsubscribe();
            }, []);

            // 3. SAVE DATA (Ensuring Numbers)
            const handleAddStudent = (e) => {
                e.preventDefault();
                if (!newName || !newGrade) return;

                STUDENTS_REF.doc(newName).set({
                    name: newName,
                    grade: Number(newGrade), // CRITICAL: Convert string to number
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                }, { merge: true });

                setNewName("");
                setNewGrade("");
            };

            const handleDelete = (id) => {
                STUDENTS_REF.doc(id).delete();
            };

            return (
                <div className="min-h-screen">
                    <header className="bg-school-blue text-white p-8 border-b-4 border-school-lightBlue">
                        <div className="max-w-4xl mx-auto">
                            <h1 className="text-3xl font-bold">SS Grade Tracker</h1>
                            <p className="text-blue-200 text-sm mt-1">Connected to: {firebaseConfig.projectId}</p>
                        </div>
                    </header>

                    <main className="max-w-4xl mx-auto p-6">
                        {/* Input Section */}
                        <div className="bg-white p-6 rounded-xl shadow-md mb-8">
                            <h2 className="text-xl font-bold mb-4">Add Student Record</h2>
                            <form onSubmit={handleAddStudent} className="flex flex-wrap gap-4">
                                <input 
                                    type="text" 
                                    placeholder="Student Name" 
                                    value={newName}
                                    onChange={(e) => setNewName(e.target.value)}
                                    className="flex-1 p-3 border rounded-lg outline-none focus:ring-2 ring-school-lightBlue"
                                />
                                <input 
                                    type="number" 
                                    placeholder="Grade" 
                                    value={newGrade}
                                    onChange={(e) => setNewGrade(e.target.value)}
                                    className="w-32 p-3 border rounded-lg outline-none focus:ring-2 ring-school-lightBlue"
                                />
                                <button className="bg-school-lightBlue text-white px-6 py-3 rounded-lg font-bold hover:bg-school-blue transition">
                                    Save Record
                                </button>
                            </form>
                        </div>

                        {/* Data Display */}
                        <div className="bg-white rounded-xl shadow-md overflow-hidden">
                            <table className="w-full text-left">
                                <thead className="bg-gray-100 border-b">
                                    <tr>
                                        <th className="p-4 font-bold">Student Name</th>
                                        <th className="p-4 font-bold text-center">Current Grade</th>
                                        <th className="p-4 font-bold text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {loading ? (
                                        <tr><td colSpan="3" className="p-8 text-center text-gray-500">Loading from ssgradetracker...</td></tr>
                                    ) : students.length === 0 ? (
                                        <tr><td colSpan="3" className="p-8 text-center text-gray-500">No data found. Add a student to begin.</td></tr>
                                    ) : (
                                        students.map(student => (
                                            <tr key={student.id} className="border-b hover:bg-gray-50">
                                                <td className="p-4 font-medium">{student.name}</td>
                                                <td className="p-4 text-center">
                                                    <span className={`px-3 py-1 rounded-full font-bold ${student.grade >= 70 ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700'}`}>
                                                        {student.grade}%
                                                    </span>
                                                </td>
                                                <td className="p-4 text-right">
                                                    <button onClick={() => handleDelete(student.id)} className="text-red-500 hover:text-red-700 font-bold text-sm">Delete</button>
                                                </td>
                                            </tr>
                                        ))
                                    )}
                                </tbody>
                            </table>
                        </div>
                    </main>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<DataTracker />);
    </script>
</body>
</html>
